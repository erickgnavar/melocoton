<div
  class="flex flex-col h-full"
  style="background: var(--bg-primary); border-left: 1px solid var(--border-medium);"
>
  <%!-- Header --%>
  <div
    class="px-3 py-3 flex items-center justify-between text-xs app-section-border"
    style="background: var(--bg-secondary);"
  >
    <div class="flex items-center gap-2">
      <.icon name="lucide-bot" class="size-4" style={"color: #{@database.group.color};"} />
      <span class="font-medium">AI Assistant</span>
    </div>
    <div class="flex items-center gap-1">
      <button
        phx-click="toggle-history"
        phx-target={@myself}
        class="icon-btn"
        title="Chat history"
        aria-label="Chat history"
      >
        <.icon name="lucide-history" class="size-3.5" />
      </button>
      <button
        phx-click="new-chat"
        phx-target={@myself}
        class="icon-btn"
        title="New chat"
        aria-label="New chat"
      >
        <.icon name="lucide-plus" class="size-3.5" />
      </button>
      <button
        phx-click="close-panel"
        phx-target={@myself}
        class="icon-btn"
        title="Close panel"
        aria-label="Close panel"
      >
        <.icon name="lucide-x" class="size-3.5" />
      </button>
    </div>
  </div>

  <%!-- History panel --%>
  <%= if @show_history do %>
    <div
      class="overflow-y-auto text-xs border-b"
      style="background: var(--bg-secondary); border-color: var(--border-medium); max-height: 50%;"
    >
      <div
        class="px-3 py-2 flex items-center justify-between"
        style="color: var(--text-tertiary);"
      >
        <span class="font-medium text-[10px] uppercase tracking-wide">Chat History</span>
      </div>
      <%= if @archived_chats == [] do %>
        <div class="px-3 py-4 text-center" style="color: var(--text-tertiary);">
          <p class="text-[10px]">No previous chats</p>
        </div>
      <% else %>
        <div class="flex flex-col">
          <div
            :for={chat <- @archived_chats}
            class="flex items-center justify-between px-3 py-1.5 cursor-pointer group"
            style="border-bottom: 0.5px solid var(--border-subtle);"
            phx-click="view-chat"
            phx-value-chat-id={chat.id}
            phx-target={@myself}
          >
            <div class="flex-1 min-w-0 mr-2">
              <p class="truncate text-[11px]" style="color: var(--text-primary);">
                {chat.title || "Untitled chat"}
              </p>
              <p class="text-[9px]" style="color: var(--text-tertiary);">
                {Calendar.strftime(chat.archived_at, "%b %d, %H:%M")}
              </p>
            </div>
            <button
              phx-click="delete-chat"
              phx-value-chat-id={chat.id}
              phx-target={@myself}
              class="icon-btn opacity-0 group-hover:opacity-100 shrink-0"
              title="Delete chat"
              aria-label="Delete chat"
            >
              <.icon name="lucide-trash-2" class="size-3" />
            </button>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%!-- Viewing archived banner --%>
  <%= if @viewing_archived do %>
    <div
      class="px-3 py-1.5 flex items-center justify-between text-[10px]"
      style="background: var(--bg-tertiary); border-bottom: 0.5px solid var(--border-medium); color: var(--text-secondary);"
    >
      <span class="truncate mr-2">
        <.icon name="lucide-archive" class="size-3 mr-1 inline-block" />
        {@current_chat.title || "Untitled chat"}
      </span>
      <button
        phx-click="back-to-active"
        phx-target={@myself}
        class="shrink-0 font-medium hover:underline"
        style={"color: #{@database.group.color};"}
      >
        Back to current
      </button>
    </div>
  <% end %>

  <%!-- Messages --%>
  <div
    id="ai-chat-messages"
    class="flex-1 overflow-y-auto p-3 space-y-3 text-xs"
    phx-hook="AiChatScroll"
  >
    <%= if @messages == [] do %>
      <div
        class="flex flex-col items-center justify-center h-full text-center"
        style="color: var(--text-tertiary);"
      >
        <.icon
          name="lucide-message-square"
          class={["size-7", "mb-3"]}
          style={"color: #{@database.group.color}33;"}
        />
        <p class="text-[11px] font-medium mb-1">Ask me about your database</p>
        <p class="text-[10px] mb-3">
          I know the schema and can help you build queries.
        </p>
        <div class="flex flex-col gap-1.5 w-full px-2">
          <button
            :for={
              prompt <- [
                "Show all tables and their row counts",
                "Find duplicate rows",
                "Show the largest tables by size"
              ]
            }
            class="text-[10px] text-left px-2.5 py-1.5 rounded cursor-pointer"
            style="background: var(--bg-tertiary); color: var(--text-secondary); border: 0.5px solid var(--border-subtle);"
            phx-click="send-suggestion"
            phx-value-message={prompt}
            phx-target={@myself}
          >
            <.icon
              name="lucide-arrow-right"
              class="size-4 mr-1 inline-block"
              style={"color: #{@database.group.color};"}
            />
            {prompt}
          </button>
        </div>
      </div>
    <% else %>
      <div :for={msg <- @messages} class="flex flex-col gap-1 group/msg">
        <%= if msg.role == "user" do %>
          <div class="flex justify-end items-start gap-1">
            <%= if not @viewing_archived and @confirm_delete_message_id == msg.id do %>
              <div class="flex items-center gap-1 shrink-0 self-center">
                <button
                  phx-click="delete-message"
                  phx-value-message-id={msg.id}
                  phx-target={@myself}
                  class="px-1.5 py-0.5 rounded text-[10px]"
                  style="background: var(--bg-tertiary); color: #ef4444;"
                >
                  Delete
                </button>
                <button
                  phx-click="cancel-delete-message"
                  phx-target={@myself}
                  class="px-1.5 py-0.5 rounded text-[10px]"
                  style="background: var(--bg-tertiary); color: var(--text-tertiary);"
                >
                  Cancel
                </button>
              </div>
            <% else %>
              <button
                :if={not @viewing_archived}
                phx-click="confirm-delete-message"
                phx-value-message-id={msg.id}
                phx-target={@myself}
                class="icon-btn opacity-0 group-hover/msg:opacity-100 shrink-0 self-center"
                title="Delete message"
              >
                <.icon name="lucide-trash-2" class="size-3" />
              </button>
            <% end %>
            <div
              class="px-2.5 py-1.5 rounded-lg max-w-[90%] ai-markdown ai-markdown-user"
              style={"background: #{@database.group.color}; color: white;"}
            >
              {render_markdown(msg.content)}
            </div>
          </div>
        <% else %>
          <div class="flex justify-start items-start gap-1">
            <div
              class="px-2.5 py-1.5 rounded-lg max-w-[90%]"
              style="background: var(--bg-tertiary); color: var(--text-primary);"
            >
              <span :for={part <- parse_message_parts(msg.content)}>
                <%= case part do %>
                  <% {:sql, sql} -> %>
                    <div class="my-1.5">
                      <.sql_block sql={sql} class="text-[10px]" />
                      <div class="flex gap-1 mt-1">
                        <button
                          phx-click="insert-sql"
                          phx-value-sql={sql}
                          phx-target={@myself}
                          class="px-1.5 py-0.5 rounded text-[10px] opacity-70 hover:opacity-100"
                          style={"background: #{@database.group.color}22; color: #{@database.group.color};"}
                        >
                          <.icon name="lucide-file-input" class="size-3 mr-0.5 inline-block" />
                          Insert
                        </button>
                        <button
                          phx-click="run-sql"
                          phx-value-sql={sql}
                          phx-target={@myself}
                          class="px-1.5 py-0.5 rounded text-[10px] opacity-70 hover:opacity-100"
                          style="background: var(--bg-secondary); color: var(--text-secondary);"
                        >
                          <.icon name="lucide-play" class="size-3 mr-0.5 inline-block" /> Run
                        </button>
                        <button
                          phx-click={
                            JS.dispatch("phx:copy",
                              detail: %{text: sql},
                              to: "#ai-chat-messages"
                            )
                          }
                          class="px-1.5 py-0.5 rounded text-[10px] opacity-70 hover:opacity-100"
                          style="background: var(--bg-secondary); color: var(--text-secondary);"
                          title="Copy to clipboard"
                        >
                          <.icon name="lucide-copy" class="size-3 mr-0.5 inline-block" /> Copy
                        </button>
                      </div>
                    </div>
                  <% {:markdown, html} -> %>
                    <div class="ai-markdown">{html}</div>
                <% end %>
              </span>
            </div>
            <%= if not @viewing_archived and @confirm_delete_message_id == msg.id do %>
              <div class="flex items-center gap-1 shrink-0 self-center">
                <button
                  phx-click="delete-message"
                  phx-value-message-id={msg.id}
                  phx-target={@myself}
                  class="px-1.5 py-0.5 rounded text-[10px]"
                  style="background: var(--bg-tertiary); color: #ef4444;"
                >
                  Delete
                </button>
                <button
                  phx-click="cancel-delete-message"
                  phx-target={@myself}
                  class="px-1.5 py-0.5 rounded text-[10px]"
                  style="background: var(--bg-tertiary); color: var(--text-tertiary);"
                >
                  Cancel
                </button>
              </div>
            <% else %>
              <button
                :if={not @viewing_archived}
                phx-click="confirm-delete-message"
                phx-value-message-id={msg.id}
                phx-target={@myself}
                class="icon-btn opacity-0 group-hover/msg:opacity-100 shrink-0 self-center"
                title="Delete message"
              >
                <.icon name="lucide-trash-2" class="size-3" />
              </button>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= if @loading do %>
      <div class="flex justify-start">
        <div
          class="px-2.5 py-1.5 rounded-lg"
          style="background: var(--bg-tertiary); color: var(--text-tertiary);"
        >
          <.icon name="lucide-loader-2" class="size-3 mr-1 inline-block animate-spin" />
          Thinking...
        </div>
      </div>
    <% end %>
  </div>

  <%!-- Error --%>
  <%= if @error do %>
    <div class="error-banner m-0 rounded-none">
      <.icon name="lucide-alert-circle" class="size-4 mr-1 inline-block" />{@error}
    </div>
  <% end %>

  <%!-- Input (hidden when viewing archived chat) --%>
  <%= if not @viewing_archived do %>
    <form
      phx-submit="send-message"
      phx-target={@myself}
      class="px-3 py-2 flex items-center gap-2 app-status-bar"
    >
      <input
        id="ai-chat-input"
        type="text"
        name="message"
        value={@input}
        placeholder="Ask about your database..."
        autocomplete="off"
        disabled={@loading}
        class="flex-1 px-2.5 py-1.5 text-xs rounded"
        style="background: var(--bg-primary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
        phx-change="update-input"
        phx-target={@myself}
      />
      <button
        type="submit"
        disabled={@loading}
        class="px-2 py-1.5 rounded text-xs font-medium"
        style={"background: #{@database.group.color}; color: white;"}
      >
        <.icon name="lucide-send" class="size-3.5" />
      </button>
    </form>
  <% end %>
</div>
