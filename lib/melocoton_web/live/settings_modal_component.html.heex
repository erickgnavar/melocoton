<form phx-submit="save-settings" phx-target={@myself} class="p-4 space-y-4">
  <div
    class="text-[10px] uppercase font-semibold tracking-wide mb-3"
    style="color: var(--text-tertiary);"
  >
    Appearance
  </div>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: var(--text-secondary);">
      Font Size
    </label>
    <div class="flex items-center gap-2">
      <div class="flex gap-1">
        <button
          :for={
            {label, value} <- [
              {"XS", "xs"},
              {"S", "sm"},
              {"M", "md"},
              {"L", "lg"},
              {"XL", "xl"}
            ]
          }
          type="button"
          phx-click="set-font-size"
          phx-value-size={value}
          phx-target={@myself}
          class="px-2 py-1 text-xs rounded font-medium"
          style={
            if @font_size == value,
              do: "background: var(--focus-color); color: white;",
              else:
                "background: var(--bg-tertiary); color: var(--text-secondary); border: 0.5px solid var(--border-medium);"
          }
        >
          {label}
        </button>
      </div>
      <span class="text-[10px]" style="color: var(--text-tertiary);">or</span>
      <input
        type="number"
        name="font_size_px"
        min="8"
        max="24"
        step="1"
        value={@font_size_px}
        phx-change="set-font-size-px"
        phx-target={@myself}
        phx-debounce="300"
        class="w-16 px-2 py-1 text-xs rounded text-center"
        style="background: var(--bg-secondary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
      />
      <span class="text-[10px]" style="color: var(--text-tertiary);">px</span>
    </div>
    <input type="hidden" name="font_size" value={@font_size} />
  </div>

  <div class="w-full h-px" style="background: var(--border-medium);"></div>

  <div
    class="text-[10px] uppercase font-semibold tracking-wide mb-3"
    style="color: var(--text-tertiary);"
  >
    LLM Provider API Keys
  </div>

  <div class="space-y-3">
    <div>
      <label class="block text-xs font-medium mb-1" style="color: var(--text-secondary);">
        AI Model
      </label>
      <input
        type="text"
        name="ai_model"
        value={@settings["ai_model"]}
        placeholder="e.g. anthropic:claude-haiku-4-5"
        class="w-full px-2.5 py-1.5 text-xs rounded"
        style="background: var(--bg-secondary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
      />
      <p class="mt-0.5 text-[10px]" style="color: var(--text-tertiary);">
        Format: provider:model-name (e.g. openrouter:minimax/minimax-01)
      </p>
    </div>

    <div class="w-full h-px" style="background: var(--border-medium);"></div>

    <div>
      <label class="block text-xs font-medium mb-1" style="color: var(--text-secondary);">
        <.icon name="lucide-key-round" class="w-3 h-3 mr-1 inline-block" /> Anthropic API Key
      </label>
      <input
        type="password"
        name="anthropic_api_key"
        value={@settings["anthropic_api_key"]}
        placeholder={
          if @settings["anthropic_api_key"] != "",
            do: mask_key(@settings["anthropic_api_key"]),
            else: "sk-ant-..."
        }
        class="w-full px-2.5 py-1.5 text-xs rounded"
        style="background: var(--bg-secondary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
      />
    </div>

    <div>
      <label class="block text-xs font-medium mb-1" style="color: var(--text-secondary);">
        <.icon name="lucide-key-round" class="w-3 h-3 mr-1 inline-block" /> OpenAI API Key
      </label>
      <input
        type="password"
        name="openai_api_key"
        value={@settings["openai_api_key"]}
        placeholder={
          if @settings["openai_api_key"] != "",
            do: mask_key(@settings["openai_api_key"]),
            else: "sk-..."
        }
        class="w-full px-2.5 py-1.5 text-xs rounded"
        style="background: var(--bg-secondary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
      />
    </div>

    <div>
      <label class="block text-xs font-medium mb-1" style="color: var(--text-secondary);">
        <.icon name="lucide-key-round" class="w-3 h-3 mr-1 inline-block" /> OpenRouter API Key
      </label>
      <input
        type="password"
        name="openrouter_api_key"
        value={@settings["openrouter_api_key"]}
        placeholder={
          if @settings["openrouter_api_key"] != "",
            do: mask_key(@settings["openrouter_api_key"]),
            else: "sk-or-..."
        }
        class="w-full px-2.5 py-1.5 text-xs rounded"
        style="background: var(--bg-secondary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
      />
      <p class="mt-0.5 text-[10px]" style="color: var(--text-tertiary);">
        Gives access to 200+ models including Minimax, Anthropic, OpenAI, Google, Meta
      </p>
    </div>

    <div>
      <label class="block text-xs font-medium mb-1" style="color: var(--text-secondary);">
        <.icon name="lucide-key-round" class="w-3 h-3 mr-1 inline-block" /> Minimax API Key
      </label>
      <input
        type="password"
        name="minimax_api_key"
        value={@settings["minimax_api_key"]}
        placeholder={
          if @settings["minimax_api_key"] != "",
            do: mask_key(@settings["minimax_api_key"]),
            else: "eyJ..."
        }
        class="w-full px-2.5 py-1.5 text-xs rounded"
        style="background: var(--bg-secondary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
      />
    </div>
  </div>

  <%!-- Footer --%>
  <div
    class="flex items-center justify-between pt-3"
    style="border-top: 1px solid var(--border-medium);"
  >
    <div>
      <%= if @saved do %>
        <span class="text-xs text-green-500">
          <.icon name="lucide-check" class="w-4 h-4 mr-1 inline-block" /> Settings saved
        </span>
      <% end %>
    </div>
    <button
      type="submit"
      class="px-3 py-1.5 text-xs rounded font-medium text-white"
      style="background: var(--focus-color);"
    >
      Save
    </button>
  </div>
</form>
