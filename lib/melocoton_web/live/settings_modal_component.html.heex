<form phx-submit="save-settings" phx-target={@myself} class="p-4 space-y-4">
  <div
    class="text-[10px] uppercase font-semibold tracking-wide mb-3"
    style="color: var(--text-tertiary);"
  >
    Appearance
  </div>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: var(--text-secondary);">
      Font Size
    </label>
    <div class="flex items-center gap-2">
      <div class="flex gap-1">
        <button
          :for={
            {label, value} <- [
              {"XS", "xs"},
              {"S", "sm"},
              {"M", "md"},
              {"L", "lg"},
              {"XL", "xl"}
            ]
          }
          type="button"
          phx-click="set-font-size"
          phx-value-size={value}
          phx-target={@myself}
          class="px-2 py-1 text-xs rounded font-medium"
          style={
            if @font_size == value,
              do: "background: var(--focus-color); color: white;",
              else:
                "background: var(--bg-tertiary); color: var(--text-secondary); border: 0.5px solid var(--border-medium);"
          }
        >
          {label}
        </button>
      </div>
      <span class="text-[10px]" style="color: var(--text-tertiary);">or</span>
      <input
        type="number"
        name="font_size_px"
        min="8"
        max="24"
        step="1"
        value={@font_size_px}
        phx-change="set-font-size-px"
        phx-target={@myself}
        phx-debounce="300"
        class="w-16 px-2 py-1 text-xs rounded text-center"
        style="background: var(--bg-secondary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
      />
      <span class="text-[10px]" style="color: var(--text-tertiary);">px</span>
    </div>
    <input type="hidden" name="font_size" value={@font_size} />
  </div>

  <div class="w-full h-px" style="background: var(--border-medium);"></div>

  <div
    class="text-[10px] uppercase font-semibold tracking-wide mb-3"
    style="color: var(--text-tertiary);"
  >
    Editor
  </div>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: var(--text-secondary);">
      Keybindings
    </label>
    <div class="flex gap-1">
      <button
        :for={
          {label, value, hint} <- [
            {"Vim", "vim", "Vim keybindings with ex-commands"},
            {"Standard", "standard", "Standard text editing"}
          ]
        }
        type="button"
        phx-click="set-editor-mode"
        phx-value-mode={value}
        phx-target={@myself}
        class="px-3 py-1.5 text-xs rounded font-medium"
        style={
          if @editor_mode == value,
            do: "background: var(--focus-color); color: white;",
            else:
              "background: var(--bg-tertiary); color: var(--text-secondary); border: 0.5px solid var(--border-medium);"
        }
        title={hint}
      >
        {label}
      </button>
    </div>
  </div>

  <div class="w-full h-px" style="background: var(--border-medium);"></div>

  <div
    class="text-[10px] uppercase font-semibold tracking-wide mb-3"
    style="color: var(--text-tertiary);"
  >
    LLM Provider API Keys
  </div>

  <div class="space-y-3">
    <div class="flex gap-3">
      <div class="flex-1">
        <label class="block text-xs font-medium mb-1" style="color: var(--text-secondary);">
          Provider
        </label>
        <select
          name="provider"
          phx-change="change-provider"
          phx-target={@myself}
          class="w-full appearance-none px-2.5 py-1.5 text-xs rounded"
          style="background: var(--bg-secondary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
        >
          <option value="">Select provider...</option>
          <%= for {label, id} <- Melocoton.AI.Models.provider_options() do %>
            <option value={id} selected={@provider == id}>{label}</option>
          <% end %>
        </select>
      </div>
      <div class="flex-1">
        <label class="block text-xs font-medium mb-1" style="color: var(--text-secondary);">
          Model
        </label>
        <select
          name="model"
          phx-change="change-model"
          phx-target={@myself}
          class="w-full appearance-none px-2.5 py-1.5 text-xs rounded"
          style="background: var(--bg-secondary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
          disabled={@provider == nil}
        >
          <option value="">Select model...</option>
          <%= for {label, id} <- @model_options do %>
            <option value={id} selected={@model == id}>{label}</option>
          <% end %>
        </select>
      </div>
    </div>

    <p
      :if={@provider == "ollama" and @model_options == []}
      class="mt-1 text-[10px]"
      style="color: var(--text-tertiary);"
    >
      No models found. Make sure Ollama is running
      (<code style="color: var(--syntax-keyword);">ollama serve</code>)
    </p>
    <p
      :if={@provider == "ollama" and @model_options != []}
      class="mt-1 text-[10px]"
      style="color: var(--text-tertiary);"
    >
      Showing models installed locally. To download new models run:
      <code style="color: var(--syntax-keyword);">ollama pull &lt;model-name&gt;</code>
    </p>

    <div class="w-full h-px" style="background: var(--border-medium);"></div>

    <%= for {key_name, label, placeholder} <- [
      {"anthropic_api_key", "Anthropic API Key", "sk-ant-..."},
      {"openai_api_key", "OpenAI API Key", "sk-..."},
      {"openrouter_api_key", "OpenRouter API Key", "sk-or-..."},
      {"minimax_api_key", "MiniMax API Key", "sk-cp-..."}
    ] do %>
      <div>
        <label
          class="flex items-center text-xs font-medium mb-1"
          style="color: var(--text-secondary);"
        >
          <.icon name="lucide-key-round" class="size-3 mr-1" />
          {label}
          <span
            :if={@required_key == key_name}
            class="ml-1.5 text-[9px] uppercase tracking-wide font-semibold"
            style="color: var(--focus-color);"
          >
            required
          </span>
        </label>
        <input
          type="password"
          name={key_name}
          value={@settings[key_name]}
          required={@required_key == key_name}
          placeholder={
            if @settings[key_name] != "",
              do: mask_key(@settings[key_name]),
              else: placeholder
          }
          class="w-full px-2.5 py-1.5 text-xs rounded"
          style={
            if @required_key == key_name,
              do:
                "background: var(--bg-secondary); border: 1px solid var(--focus-color); color: var(--text-primary);",
              else:
                "background: var(--bg-secondary); border: 0.5px solid var(--border-medium); color: var(--text-primary);"
          }
        />
        <p
          :if={key_name == "openrouter_api_key"}
          class="mt-0.5 text-[10px]"
          style="color: var(--text-tertiary);"
        >
          Gives access to 200+ models including Minimax, Anthropic, OpenAI, Google, Meta
        </p>
      </div>
    <% end %>
  </div>

  <%!-- Footer --%>
  <div
    class="flex items-center justify-between pt-3"
    style="border-top: 1px solid var(--border-medium);"
  >
    <div class="flex items-center gap-3">
      <%= if @saved do %>
        <span class="text-xs text-green-500">
          <.icon name="lucide-check" class="size-4 mr-1 inline-block" /> Settings saved
        </span>
      <% end %>
      <button
        type="button"
        phx-click="show-onboarding"
        phx-target={@myself}
        class="text-[10px] hover:underline"
        style="color: var(--text-tertiary);"
      >
        Show welcome tutorial
      </button>
    </div>
    <button
      type="submit"
      class="px-3 py-1.5 text-xs rounded font-medium text-white"
      style="background: var(--focus-color);"
    >
      Save
    </button>
  </div>
</form>
